# AccuDesign .env — Phase 4
# Copy this to .env and fill in your API keys

# ── Metal Pricing API (metals.dev) ───────────────────────────────────────────
# Sign up FREE at https://metals.dev (100 req/month, no credit card)
# Provides real-time LME prices for Aluminum, Copper, Nickel, Zinc, Lead, etc.
METALS_DEV_API_KEY=your_key_here

# ── If left blank, World Bank Pink Sheet API is used (free, no key needed) ───
# World Bank: https://api.worldbank.org/v2 — updated monthly, no rate limits

# ── Google Gemini API Key (for PDF drawing analysis) ─────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
# Used to analyze uploaded PDF engineering drawings (dimensions, materials, etc.)
GEMINI_API_KEY=your_gemini_key_here
